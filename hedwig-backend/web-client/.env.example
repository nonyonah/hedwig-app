# Reown AppKit Project ID
# Obtain from https://cloud.reown.com/
VITE_REOWN_PROJECT_ID=your_project_id_here

# Backend API URL
VITE_API_URL=https://pay.hedwigbot.xyz

# Solana RPC proxy endpoint (recommended: backend proxy so API keys stay server-side)
VITE_SOLANA_RPC_PROXY_URL=https://pay.hedwigbot.xyz/api/solana/rpc?cluster=devnet
# Optional comma-separated non-sensitive fallback RPC endpoints
VITE_SOLANA_RPC_FALLBACKS=

# Privy App ID
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Coinbase OnchainKit API key (optional, recommended)
VITE_ONCHAINKIT_API_KEY=
# Optional custom RPC URLs for Wagmi/OnchainKit
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_BASE_MAINNET_RPC_URL=https://mainnet.base.org

# UserJot Project ID (for feedback widget)
VITE_USERJOT_PROJECT_ID=your_userjot_project_id

# Web client URL
EXPO_PUBLIC_WEB_CLIENT_URL=https://pay.hedwigbot.xyz
