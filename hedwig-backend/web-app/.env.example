# Network mode: "mainnet" (default) or "testnet"
NEXT_PUBLIC_NETWORK_MODE=mainnet
NEXT_PUBLIC_API_URL=https://hedwigbot.xyz
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_USERBACK_TOKEN=
NEXT_PUBLIC_HEDWIG_USE_MOCK_AUTH=true
NEXT_PUBLIC_HEDWIG_USE_MOCK_DATA=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Polar Web Billing (server-side Next.js routes)
POLAR_ACCESS_TOKEN=
# Use "sandbox" for local testing and "production" for live billing.
POLAR_SERVER=sandbox
# Product IDs from Polar dashboard (one for each billing interval).
POLAR_PRODUCT_ID_MONTHLY=
POLAR_PRODUCT_ID_ANNUAL=
# Optional: discount ID from Polar dashboard applied to annual checkout.
POLAR_DISCOUNT_ID_ANNUAL=
# Optional: number of trial days to offer at checkout (0 = no trial).
POLAR_TRIAL_DAYS=7
# Optional route redirect targets.
POLAR_CHECKOUT_SUCCESS_URL=http://localhost:3001/pricing/success
POLAR_CHECKOUT_RETURN_URL=http://localhost:3001/pricing
POLAR_PORTAL_RETURN_URL=http://localhost:3001/settings
# Region locks (optional)
# Example:
# REGION_LOCKS_JSON={"offramp":{"allow":["NG","GH"],"reason":"Offramp is currently limited to supported markets."},"usd_account":{"allow":["US"],"reason":"USD account is currently available only in supported regions."}}
# Shell-safe example:
# export REGION_LOCKS_JSON='{"offramp":{"allow":["NG","GH"],"reason":"Offramp is currently limited to supported markets."},"usd_account":{"allow":["US"],"reason":"USD account is currently available only in supported regions."}}'
export REGION_LOCKS_JSON='{"offramp":{"allow":["NG","GH"],"reason":"Offramp is currently limited to supported markets."},"usd_account":{"allow":["NG"],"reason":"USD account is currently available only in supported regions."}}'

# If false, unknown country headers are treated as blocked for locked features.
REGION_LOCK_FAIL_OPEN=true
# Optional fallback country when no geo headers are present (e.g. local dev): US
REGION_LOCK_DEFAULT_COUNTRY=
