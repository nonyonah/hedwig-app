# Network mode: "mainnet" (default) or "testnet"
NEXT_PUBLIC_NETWORK_MODE=mainnet
NEXT_PUBLIC_API_URL=https://pay.riftlabs.xyz
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
NEXT_PUBLIC_USERBACK_TOKEN=
NEXT_PUBLIC_HEDWIG_USE_MOCK_AUTH=true
NEXT_PUBLIC_HEDWIG_USE_MOCK_DATA=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Sentry web monitoring. NEXT_PUBLIC_SENTRY_DSN is safe to expose; keep auth token server/build-only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ORG=hedwig-dd
SENTRY_PROJECT=web-app
SENTRY_AUTH_TOKEN=
# Polar Web Billing (server-side Next.js routes)
POLAR_ACCESS_TOKEN=
# Use "sandbox" for local testing and "production" for live billing.
POLAR_SERVER=sandbox
# Product IDs from Polar dashboard (one for each billing interval).
# Legacy Polar product IDs (existing subscribers)
POLAR_PRODUCT_ID_MONTHLY=
POLAR_PRODUCT_ID_ANNUAL=

# Starter plan product IDs
POLAR_STARTER_MONTHLY_ID=
POLAR_STARTER_ANNUAL_ID=
POLAR_STARTER_ANNUAL_DISCOUNT_ID=

# Pro plan product IDs
POLAR_PRO_MONTHLY_ID=
POLAR_PRO_ANNUAL_ID=
POLAR_PRO_ANNUAL_DISCOUNT_ID=
# Optional: number of trial days to offer at checkout (0 = no trial).
POLAR_TRIAL_DAYS=7
# Optional route redirect targets.
POLAR_CHECKOUT_SUCCESS_URL=http://localhost:3001/pricing/success
POLAR_CHECKOUT_RETURN_URL=http://localhost:3001/pricing
POLAR_PORTAL_RETURN_URL=http://localhost:3001/settings
# Region locks (optional — defaults are set in lib/region-lock.ts for offramp)
# Override default allowed countries for offramp (NG, GH, KE, MW, TZ, BR) or usd_account (NG).
# Example:
# REGION_LOCKS_JSON={"offramp":{"allow":["NG","GH","KE","MW","TZ","BR"],"reason":"Offramp is not available in your region."},"usd_account":{"allow":["NG"],"reason":"USD account is not available in your region."}}
# Shell-safe example:
# export REGION_LOCKS_JSON='{"offramp":{"allow":["NG","GH","KE","MW","TZ","BR"],"reason":"..."}}'
export REGION_LOCKS_JSON='{"offramp":{"allow":["NG","GH","KE","MW","TZ","BR"],"reason":"Offramp is not available in your region."},"usd_account":{"allow":["NG"],"reason":"USD account is not available in your region."}}'

# If true, unknown regions are allowed for locked features. Default: false (block unknown regions).
REGION_LOCK_FAIL_OPEN=false
# Optional fallback country when no geo headers are present (e.g. local dev): US
REGION_LOCK_DEFAULT_COUNTRY=

# ─── Integrations ─────────────────────────────────────────────────────────────
# Full public URL of the web app — used to build OAuth redirect URIs
# Must match the origin registered in Google Cloud Console and Slack App settings
NEXT_PUBLIC_WEB_URL=http://localhost:3001
