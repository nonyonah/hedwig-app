# BlockRadar Configuration
BLOCKRADAR_API_KEY=
BLOCKRADAR_BASE_WALLET_ID=

# Alchemy Webhooks (Address Activity – Base, Arbitrum, Optimism, Polygon, Celo, Solana).
# Use raw body for signature verification.
# Get signing key from Alchemy Dashboard → Webhooks → AUTH TOKEN (per app or per webhook).
ALCHEMY_AUTH_TOKEN=
ALCHEMY_BASE_WEBHOOK_ID=
ALCHEMY_ARBITRUM_WEBHOOK_ID=
ALCHEMY_OPTIMISM_WEBHOOK_ID=
ALCHEMY_POLYGON_WEBHOOK_ID=
ALCHEMY_CELO_WEBHOOK_ID=
ALCHEMY_SOLANA_WEBHOOK_ID=
ALCHEMY_SIGNING_KEY_BASE=
ALCHEMY_SIGNING_KEY_ARBITRUM=
ALCHEMY_SIGNING_KEY_OPTIMISM=
ALCHEMY_SIGNING_KEY_POLYGON=
ALCHEMY_SIGNING_KEY_CELO=
ALCHEMY_SIGNING_KEY_SOLANA=
# Optional: single key used when network-specific key is not set
ALCHEMY_SIGNING_KEY=

# RevenueCat billing sync
# Webhook auth value configured in RevenueCat dashboard (sent in Authorization header).
REVENUECAT_WEBHOOK_AUTH=
# Polar billing sync
# Secret from Polar webhook endpoint settings for /api/webhooks/payments.
POLAR_WEBHOOK_SECRET=
# Hedwig paid entitlement identifier in RevenueCat.
REVENUECAT_PRIMARY_ENTITLEMENT_ID=pro
# Legacy web checkout links (optional fallback if not using RevenueCat Web SDK checkout).
# For SDK-based checkout, configure NEXT_PUBLIC_REVENUECAT_* vars in web-app/.env.local.
# Set these only if you still use backend checkout-link redirects.
# Example:
# REVENUECAT_WEB_CHECKOUT_MONTHLY_URL=https://pay.rev.cat/xxxxxxxxxxxxxxxx
# REVENUECAT_WEB_CHECKOUT_ANNUAL_URL=https://pay.rev.cat/yyyyyyyyyyyyyyyy
REVENUECAT_WEB_CHECKOUT_MONTHLY_URL=
REVENUECAT_WEB_CHECKOUT_ANNUAL_URL=
# Rollout flags
BILLING_WEB_CHECKOUT_ENABLED=true
BILLING_MOBILE_PAYWALL_ENABLED=false
BILLING_ENFORCEMENT_ENABLED=false

# Paycrest Webhooks (offramp order status). Must match secret configured in Paycrest dashboard.
PAYCREST_WEBHOOK_SECRET=

# Bridge USD Accounts
# Set to true to enable USD account APIs
USD_ACCOUNTS_ENABLED=false
# Emergency override: enable USD accounts for all users regardless of flags/allowlist
USD_ACCOUNTS_FORCE_ENABLE=false
# Optional comma-separated internal user IDs for beta gating. Leave empty to allow all users when enabled.
USD_ACCOUNTS_BETA_ALLOWLIST=
# Example: USD_ACCOUNTS_BETA_ALLOWLIST=user@example.com,another-user-id
# Bridge API configuration
# Use production unless you explicitly want sandbox.
BRIDGE_ENV=production
BRIDGE_API_BASE_URL=https://api.bridge.xyz
BRIDGE_API_KEY=
# Bridge webhook verification public key (PEM). Use \\n in one-line env values.
BRIDGE_WEBHOOK_PUBLIC_KEY=
# Optional: your live webhook endpoint (used by setup script)
BRIDGE_USD_WEBHOOK_URL=
# Optional: persisted webhook id (used by setup script for activate/test/logs)
BRIDGE_WEBHOOK_ID=
# Comma-separated categories for webhook registration
BRIDGE_WEBHOOK_EVENT_CATEGORIES=customer,kyc_link,transfer,virtual_account,virtual_account.activity
# Per-deposit fee configuration for USD -> USDC settlement
# Set to 0 to disable deposit fees (withdrawal fees are handled in offramp flow).
USD_ACCOUNT_DEPOSIT_FEE_PERCENT=0
USD_ACCOUNT_FEE_MIN_USD=0.25
USD_ACCOUNT_FEE_MAX_USD=10.00

# Circle Gateway (unified USDC balance + transfer attestations)
# Keep as testnet while integration is in progress.
GATEWAY_NETWORK=testnet
GATEWAY_API_BASE_URL=https://gateway-api-testnet.circle.com/v1

# Broadcast notifications (feature highlights, announcements)
NOTIFICATION_BROADCAST_ENABLED=false
# Comma-separated allowlist (internal user id, email, or privy_id)
NOTIFICATION_BROADCAST_ALLOWLIST=

# Paycrest FX-rate nudges (USD -> NGN/GHS)
# Sends push + in-app (and email when available) with the latest Paycrest rates.
PAYCREST_RATE_NUDGE_INTERVAL_DAYS=2
PAYCREST_RATE_ACTIVE_LOOKBACK_DAYS=30
PAYCREST_RATE_TOKEN=USDC
PAYCREST_RATE_NETWORK=base
PAYCREST_RATE_USD_AMOUNT=1

# Optional override for email logo image URL
# Defaults to: <APP_URL>/hedwig-logo.png
EMAIL_LOGO_URL=

# Celo proof registry (safe, non-custodial onchain attestations)
# Disabled by default. When enabled, the backend anchors a hash proof when a document is marked paid.
CELO_PROOF_REGISTRY_ENABLED=false
# Supported values: celo, alfajores
CELO_PROOF_REGISTRY_NETWORK=celo
# Deployed HedwigProofRegistry contract address
CELO_PROOF_REGISTRY_ADDRESS=
# Writer key used only for proof writes (never expose, never commit).
# Prefer a dedicated low-privilege wallet for this.
CELO_PROOF_REGISTRY_WRITER_PRIVATE_KEY=
# Hardhat deploy/verify helpers
CELO_DEPLOYER_PRIVATE_KEY=
CELO_PROOF_REGISTRY_OWNER=
CELO_PROOF_REGISTRY_WRITER=
CELO_RPC_URL=https://forno.celo.org
CELO_CHAIN_ID=42220
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CELO_SEPOLIA_CHAIN_ID=11142220
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org
# Optional explorer keys. Blockscout can work with a placeholder key.
CELO_EXPLORER_API_KEY=
CELOSCAN_API_KEY=
CELO_SEPOLIA_EXPLORER_API_KEY=
CELOSCAN_ALFAJORES_API_KEY=

# OneSignal (preferred push provider for device + broadcast notifications)
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# LLM provider routing (provider-agnostic AI generation)
# Supported providers: gemini, openai
# Primary provider to use first
LLM_PROVIDER=gemini
# Optional comma-separated fallback order if primary fails
LLM_FALLBACK_PROVIDERS=openai
# Provider-specific model overrides
LLM_OPENAI_MODEL=gpt-4o-mini
LLM_GEMINI_MODEL=gemini-2.5-flash-lite
# Optional chat-specialized Gemini model for multimodal/chat parsing
LLM_GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview

# PostHog backend analytics + feature flags
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
# Feature flag key used by KYC nudge A/B copy test
POSTHOG_ONBOARDING_KYC_NUDGE_FLAG=onboarding_kyc_nudge_variant

# Userback REST feedback ingestion (mobile feedback modal -> backend -> Userback API)
# Generate API token in Userback workspace settings (Admin permissions required).
USERBACK_API_TOKEN=
# Optional: explicitly pin target project. If omitted, backend tries the first available project.
USERBACK_PROJECT_ID=

# Didit KYC
DIDIT_CLIENT_ID=
DIDIT_CLIENT_SECRET=
# Legacy aliases still supported by backend:
# DIDIT_APP_ID=
# DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
# Optional overrides:
# DIDIT_API_URL=https://api.didit.me/v3
# DIDIT_TOKEN_URL=https://api.didit.me/v3/oauth/token
# Public app origin used to build callback URLs (e.g. https://pay.hedwigbot.xyz)
PUBLIC_BASE_URL=

# Expo push token cleanup
# Set to your Expo experience/project identifier to prune tokens that belong to other projects
# Example: @your-org/your-app
EXPO_EXPECTED_EXPERIENCE_ID=

# Other variables...
PORT=3000
DATABASE_URL=
SUPABASE_URL=
SUPABASE_KEY=
WEB_CLIENT_URL=
SOLANA_RPC_URL=
# Optional comma-separated Solana RPC fallback URLs (server-side)
SOLANA_RPC_FALLBACKS=
SOLANA_DEVNET_RPC=
SOLANA_TESTNET_RPC=

# ─── Load management (Google Cloud Run) ───────────────────────────────────────

# Redis URL for shared rate limiting and distributed scheduler locks.
# Use Google Cloud Memorystore (Redis) in production.
# Format: redis://:<password>@<host>:6379  or  rediss://... for TLS
# Leave blank to fall back to per-instance in-memory rate limiting.
REDIS_URL=
# Fail startup/run when Redis is unavailable (recommended for production)
# Default behavior: true in production, false otherwise.
REDIS_FAIL_CLOSED=true

# Scheduler mode:
#   in-process  — node-cron runs inside the server (default, uses distributed lock with Redis)
#   cloud       — disables in-process cron; use GCP Cloud Scheduler to POST /internal/scheduler/<job>
SCHEDULER_MODE=in-process

# Secret token for /internal/scheduler/* endpoints (required when SCHEDULER_MODE=cloud).
# Cloud Scheduler should send: Authorization: Bearer <this value>
SCHEDULER_SECRET=

# Max users processed in parallel per scheduler job (default: 5).
SCHEDULER_CONCURRENCY=5
# Hard cap of rows fetched per run to avoid overload spikes.
SCHEDULER_MAX_USERS_PER_RUN=5000
SCHEDULER_MAX_DOCUMENTS_PER_RUN=5000
SCHEDULER_MAX_MILESTONES_PER_RUN=5000
SCHEDULER_ONESIGNAL_LAST_SEEN_LIMIT=10000

# LLM outbound protection
LLM_MAX_CONCURRENT_REQUESTS=8
LLM_MAX_QUEUE_SIZE=400

# Notifications outbound protection
NOTIFICATIONS_MAX_CONCURRENT_REQUESTS=15
NOTIFICATIONS_MAX_QUEUE_SIZE=800
NOTIFICATIONS_HTTP_TIMEOUT_MS=10000

# Insights pagination guards
INSIGHTS_PAGE_SIZE=500
INSIGHTS_MAX_ROWS=20000

# Solana RPC proxy hardening
SOLANA_RPC_UPSTREAM_TIMEOUT_MS=8000
SOLANA_RPC_MAX_BATCH_SIZE=25
SOLANA_RPC_MAX_PAYLOAD_BYTES=65536
# Optional allowlist override (comma-separated JSON-RPC methods)
# SOLANA_RPC_ALLOWED_METHODS=getBalance,getLatestBlockhash,getTransaction

# Graceful shutdown timeout in ms (default: 25000).
# Should be ≤ Cloud Run's --timeout setting.
SIGTERM_TIMEOUT_MS=25000
