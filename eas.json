{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "credentialsSource": "remote"
      },
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EXPO_PUBLIC_API_URL": "https://hedwig-1024636755109.europe-west1.run.app"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.0"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://hedwig-1024636755109.europe-west1.run.app",
        "EXPO_PUBLIC_WEB_CLIENT_URL": "https://hedwigbot.xyz",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.0",
        "credentialsSource": "remote"
      },
      "android": {
        "image": "sdk-55",
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://hedwig-1024636755109.europe-west1.run.app",
        "EXPO_PUBLIC_WEB_CLIENT_URL": "https://hedwigbot.xyz",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
